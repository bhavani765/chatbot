<!DOCTYPE html>
<html lang="en">
<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Ai Chat Bot</title>
   <link rel="stylesheet" href="style.css">
</head>
<body>
  <div class="chat-container">
  <div class="user-chat-box">
  <img src="https://cdn-icons-png.freepik.com/256/16794/16794036.png?ga=GA1.1.1008463341.1739524921&semt=ais_hybrid" alt="userimage" id="userImage">
</div>
  <div class="ai-chat-box">
  <img src="https://cdn-icons-png.freepik.com/256/6172/6172907.png?ga=GA1.1.1008463341.1739524921&semt=ais_hybrid" alt="aiimage" id="aiImage">
</div>
<div class="prompt-area"></div>
<input type="text" id="prompt" placeholder="Message...">
<button id="image"><img src="https://cdn-icons-png.freepik.com/256/7710/7710741.png?ga=GA1.1.1008463341.1739524921&semt=ais_hybrid" alt="image"></button>
<button id="submit"><img src="https://cdn-icons-png.flaticon.com/512/55/55008.png" alt="enter"></button>
   <script src="script.js"></script>
</body>
</html>

